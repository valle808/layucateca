generator client {
  provider        = "prisma-client-js"
  engineType      = "binary"
}

datasource db {
  provider  = "postgresql"
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  imageUrl    String?
  base64Image String?
  videoUrl    String?
  audioUrl    String?
  state       String   @default("Yucatán") // Yucatán, Campeche, Quintana Roo, CDMX, Jalisco, Nuevo León
  category    String   @default("Local")   // Local, Política, Economía, Deportes, Cultura
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    Comment[]
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  imageUrl    String?
  liveUrl     String?
  price       Float?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String?           // For secure email auth
  name             String?
  avatarUrl        String?           // profile avatar
  role             String            @default("USER") // USER, MODERATOR, ADMIN
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  comments         Comment[]
  reports          Report[]
  chatMessages     ChatMessage[]
  reputation       Reputation?
  marketplaceItems MarketplaceItem[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String?
  authorName String   @default("Anonymous") // Support both guest & registered comments
  author    User?    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  title       String
  description String
  mediaUrls   String   @default("[]") // JSON stringified array of images/videos
  lat         Float?
  lng         Float?
  state       String   @default("Yucatán")
  city        String   @default("Mérida")
  town        String   @default("")
  isAnonymous Boolean  @default(true)
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  aiTags      String   @default("[]") // JSON array of tags from LLM
  moderation  String   @default("UNCHECKED") // UNCHECKED, CLEAN, FLAGGED
  fbPostId    String?  // If posted to Facebook
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model ChatRoom {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  type        String        @default("PUBLIC") // PUBLIC, REGIONAL, CUSTOM
  state       String?       // For regional rooms
  city        String?       // For regional rooms
  isTemporary Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
}

model ChatMessage {
  id         String   @id @default(cuid())
  content    String
  authorId   String?
  authorName String   @default("Guest")
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model Reputation {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int      @default(100)
  badges    String   @default("[]") // JSON stringified array of strings
  updatedAt DateTime @updatedAt
}

model MarketplaceItem {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float?
  location    String   @default("Mérida, Yucatán")
  imageUrl    String?
  category    String   @default("General") // Event, Promo, ForSale
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model EmergencyAlert {
  id          String   @id @default(cuid())
  title       String
  message     String
  level       String   @default("INFO") // INFO, WARNING, DANGER
  location    String   @default("Yucatán") // Regional target
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

model Inquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  service     String   // web-design, custom-software, cybersecurity, cloud-architecture, innovations
  message     String
  budget      String?
  status      String   @default("NEW") // NEW, IN_PROGRESS, CONVERTED, CLOSED
  createdAt   DateTime @default(now())
}
